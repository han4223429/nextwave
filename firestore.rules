rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentMemberData() {
      return isSignedIn() ?
        get(/databases/$(database)/documents/members/$(request.auth.uid)).data : null;
    }

    function isAdmin() {
      return isSignedIn() && currentMemberData() != null && currentMemberData().isAdmin == true;
    }

    function isApprovedMember() {
      return isSignedIn() &&
        currentMemberData() != null &&
        currentMemberData().isMember == true;
    }

    function isSafeSelfProfileUpdate() {
      return request.resource.data.isAdmin == resource.data.isAdmin &&
        request.resource.data.isMember == resource.data.isMember &&
        request.resource.data.role == resource.data.role;
    }

    match /members/{memberId} {
      allow read: if isSignedIn() && (request.auth.uid == memberId || isAdmin());
      allow create: if isSignedIn() &&
        request.auth.uid == memberId &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.isAdmin == false &&
        request.resource.data.role in ['pending', 'member'];
      allow update: if isSignedIn() && (
        (request.auth.uid == memberId && isSafeSelfProfileUpdate()) ||
        isAdmin()
      );
      allow delete: if false;
    }

    // Example member-only content store. Replace/add collections as needed.
    match /memberPosts/{postId} {
      allow read: if isApprovedMember();
      allow write: if false;
    }
  }
}
